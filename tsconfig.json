{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@backend/*": ["./backend/src/*"]
    }
  },
  "include": ["backend/**/*.ts", "prisma.config.ts"],
  "exclude": ["node_modules", "frontend/.next"]
}
